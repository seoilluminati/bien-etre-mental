---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

const blogFiles = import.meta.glob('../../content/blog/*.md', { as: 'raw', eager: true });
const blogPosts = Object.entries(blogFiles).map(([path, raw]) => {
  const content = raw as string;
  const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
  const fm: any = {};
  if (fmMatch) {
    fmMatch[1].split('\n').forEach(line => {
      const [key, ...vals] = line.split(':');
      if (key && vals.length) fm[key.trim().replace(/"/g, '')] = vals.join(':').trim().replace(/^"|"$/g, '');
    });
  }
  return fm;
}).filter(p => p.title && p.slug)
  .sort((a, b) => new Date(b.date || 0).getTime() - new Date(a.date || 0).getTime());
---
<BaseLayout title="Blog" description="Articles, guides et comparatifs">
  <div class="container" style="padding: 2rem 0;">
    <Breadcrumb items={[
      { label: "Accueil", href: "/" },
      { label: "Blog", href: "" }
    ]} />
    <h1>Blog</h1>
    <p class="page-intro">{blogPosts.length} articles</p>
    <div class="grid-blog">
      {blogPosts.map(post => (
        <BlogCard post={post} />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .page-intro { opacity: 0.7; margin-bottom: 2rem; }
</style>
