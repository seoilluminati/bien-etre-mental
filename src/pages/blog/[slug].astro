---
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const blogFiles = import.meta.glob('../../content/blog/*.md', { as: 'raw', eager: true });
  
  return Object.entries(blogFiles).map(([path, raw]) => {
    const content = raw as string;
    const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
    const fm: any = {};
    let body = content;
    
    if (fmMatch) {
      body = content.slice(fmMatch[0].length).trim();
      fmMatch[1].split('\n').forEach(line => {
        const [key, ...vals] = line.split(':');
        if (key && vals.length) fm[key.trim().replace(/"/g, '')] = vals.join(':').trim().replace(/^"|"$/g, '');
      });
    }
    
    return {
      params: { slug: fm.slug || path.split('/').pop()?.replace('.md', '') },
      props: { frontmatter: fm, body }
    };
  }).filter(p => p.params.slug);
}

const { frontmatter, body } = Astro.props;

// Simple markdown to HTML
function mdToHtml(md: string): string {
  return md
    .replace(/^### (.*$)/gm, '<h3>$1</h3>')
    .replace(/^## (.*$)/gm, '<h2>$1</h2>')
    .replace(/^# (.*$)/gm, '<h1>$1</h1>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/^- (.*$)/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(?!<[hulo])/gm, (m) => m ? `<p>${m}` : m);
}
---
<BlogLayout
  title={frontmatter.title || "Article"}
  description={frontmatter.meta_description || ""}
  date={frontmatter.date || ""}
  author={frontmatter.author || ""}
  category={frontmatter.category || ""}
>
  <Fragment set:html={mdToHtml(body)} />
</BlogLayout>
