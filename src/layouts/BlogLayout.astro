---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TrustSignals from '../components/TrustSignals.astro';

export interface Props {
  title: string;
  description?: string;
  date?: string;
  author?: string;
  category?: string;
}
const { title, description = "", date = "", author = "", category = "" } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "author": { "@type": "Organization", "name": "Esprit Équilibre" },
  "publisher": { "@type": "Organization", "name": "Esprit Équilibre" }
};
---
<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="container blog-post">
    <Breadcrumb items={[
      { label: "Accueil", href: "/" },
      { label: "Blog", href: "/blog/" },
      { label: title, href: "" }
    ]} />
    
    <header class="post-header">
      {category && <span class="post-category">{category}</span>}
      <h1>{title}</h1>
      <div class="post-meta">
        {date && <time datetime={date}>{new Date(date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
        {author && <span class="post-author">par {author}</span>}
      </div>
    </header>
    
    <TrustSignals />
    
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post { padding: 2rem 0 4rem; max-width: 780px; }
  .post-header { margin: 1.5rem 0 2rem; }
  .post-header h1 { font-size: 2.2rem; line-height: 1.2; margin: 0.5rem 0; }
  .post-category { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
  .post-meta { display: flex; gap: 1rem; font-size: 0.9rem; opacity: 0.7; margin-top: 0.75rem; }
  .post-content { line-height: 1.8; font-size: 1.05rem; }
  .post-content h2 { font-size: 1.5rem; margin: 2rem 0 1rem; }
  .post-content h3 { font-size: 1.25rem; margin: 1.5rem 0 0.75rem; }
  .post-content p { margin: 1rem 0; }
  .post-content ul, .post-content ol { margin: 1rem 0; padding-left: 1.5rem; }
  .post-content li { margin: 0.4rem 0; }
  .post-content blockquote { padding: 1rem 1.5rem; margin: 1.5rem 0; border-left: 3px solid currentColor; font-style: italic; }
  
  @media (max-width: 768px) {
    .post-header h1 { font-size: 1.6rem; }
  }
</style>
