---
export interface Props {
  product: any;
}
const { product } = Astro.props;
const noteColor = product.note >= 8 ? 'var(--note-high)' : product.note >= 6 ? 'var(--note-mid)' : 'var(--note-low)';
const badgeType = product.note >= 9 ? 'premium' : product.note >= 8.5 ? 'choix' : product.note < 6 ? 'budget' : '';
---
<a href={`/produits/${product.slug}/`} class="product-card fade-in">
  <div class="card-top">
    {badgeType === 'premium' && <span class="badge badge-premium">★ Premium</span>}
    {badgeType === 'choix' && <span class="badge badge-choix">Choix Rédaction</span>}
    {badgeType === 'budget' && <span class="badge badge-budget">Budget</span>}
  </div>
  <div class="card-body">
    <h3 class="card-title">{product.nom_du_produit}</h3>
    {product.brand && <p class="card-brand">{product.brand}</p>}
    <div class="card-rating">
      <span class="note" style={`color: ${noteColor}`}>
        {product.note}<span style="font-size:0.65em;opacity:0.6">/10</span>
      </span>
      <div class="progress-bar">
        <div class="fill" style={`width: ${product.note * 10}%; background: ${noteColor};`}></div>
      </div>
    </div>
    <p class="card-excerpt">{product.introduction?.substring(0, 120)}...</p>
  </div>
  <div class="card-footer">
    <span class="card-cta">Voir le test complet →</span>
  </div>
</a>
