---
export interface Props {
  product: any;
}
const { product } = Astro.props;
const noteColor = product.note >= 8 ? 'var(--note-high, #4CAF50)' : product.note >= 6 ? 'var(--note-mid, #FF9800)' : 'var(--note-low, #F44336)';
const badgeType = product.note >= 8.5 ? 'choix' : product.note < 6 ? 'budget' : '';
---
<a href={`/produits/${product.slug}/`} class="product-card">
  <div class="card-top">
    {badgeType === 'choix' && <span class="badge badge-choix">Choix Rédaction</span>}
    {badgeType === 'budget' && <span class="badge badge-budget">Budget</span>}
    {product.note >= 9 && <span class="badge badge-premium">Premium</span>}
  </div>
  <div class="card-body">
    <h3 class="card-title">{product.nom_du_produit}</h3>
    {product.brand && <p class="card-brand">{product.brand}</p>}
    <div class="card-rating">
      <span class="note" style={`color: ${noteColor}`}>{product.note}/10</span>
      <div class="progress-bar">
        <div class="fill" style={`width: ${product.note * 10}%; background: ${noteColor};`}></div>
      </div>
    </div>
    <p class="card-excerpt">{product.introduction?.substring(0, 120)}...</p>
  </div>
  <div class="card-footer">
    <span class="card-cta">Voir le test →</span>
  </div>
</a>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }
  .card-top { min-height: 1.5rem; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .card-body { flex: 1; margin: 0.75rem 0; }
  .card-title { font-size: 1rem; font-weight: 700; line-height: 1.3; margin-bottom: 0.25rem; }
  .card-brand { font-size: 0.8rem; opacity: 0.6; margin-bottom: 0.5rem; }
  .card-rating { margin: 0.75rem 0; }
  .note { font-size: 1.1rem; font-weight: 800; }
  .progress-bar { margin-top: 0.35rem; }
  .card-excerpt { font-size: 0.85rem; opacity: 0.75; line-height: 1.5; }
  .card-footer { margin-top: auto; padding-top: 0.75rem; }
  .card-cta { font-size: 0.85rem; font-weight: 600; }
</style>
