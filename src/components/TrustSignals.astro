---
export interface Props {
  updatedDate?: string;
  productsCount?: number;
}
const { updatedDate, productsCount } = Astro.props;
const displayDate = updatedDate ? new Date(updatedDate).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' }) : new Date().toLocaleDateString('fr-FR', { year: 'numeric', month: 'long' });
---
<div class="trust-signals">
  <span class="trust-signal"><span class="check">✓</span> Tests indépendants</span>
  <span class="trust-signal"><span class="check">✓</span> Mis à jour {displayDate}</span>
  {productsCount && <span class="trust-signal"><span class="check">✓</span> {productsCount}+ produits testés</span>}
  <span class="trust-signal"><span class="check">✓</span> Avis vérifiés</span>
</div>
