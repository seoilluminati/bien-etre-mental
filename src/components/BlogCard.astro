---
export interface Props {
  post: { title: string; slug: string; description?: string; date?: string; category?: string; };
}
const { post } = Astro.props;
---
<a href={`/blog/${post.slug}/`} class="blog-card">
  <div class="blog-card-body">
    {post.category && <span class="blog-tag">{post.category}</span>}
    <h3>{post.title}</h3>
    {post.description && <p class="blog-excerpt">{post.description}</p>}
    {post.date && <time datetime={post.date}>{new Date(post.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
  </div>
</a>

<style>
  .blog-card {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: var(--transition);
  }
  .blog-card:hover { transform: translateY(-2px); }
  .blog-tag { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
  .blog-card h3 { font-size: 1.1rem; margin: 0.5rem 0; line-height: 1.3; }
  .blog-excerpt { font-size: 0.9rem; opacity: 0.75; line-height: 1.5; margin-bottom: 0.5rem; }
  time { font-size: 0.8rem; opacity: 0.5; }
</style>
