---
export interface Props {
  post: { title: string; slug: string; description?: string; date?: string; category?: string; readTime?: string; };
}
const { post } = Astro.props;
const readTime = post.readTime || '5 min';
---
<a href={`/blog/${post.slug}/`} class="blog-card fade-in">
  <div class="card-meta">
    {post.category && <span class="tag">{post.category}</span>}
    <span class="read-time">⏱ {readTime}</span>
  </div>
  <div class="card-content">
    <h3>{post.title}</h3>
    {post.description && <p>{post.description}</p>}
    <span class="read-more">Lire l'article →</span>
  </div>
</a>
