---
export interface Props {
  type: 'choix' | 'premium' | 'budget' | 'new' | 'bestseller';
  label?: string;
}
const { type, label } = Astro.props;
const labels: Record<string, string> = {
  choix: 'Choix Rédaction',
  premium: '★ Premium',
  budget: 'Budget',
  new: 'Nouveau',
  bestseller: 'Best-seller'
};
const displayLabel = label || labels[type] || type;
---
<span class={`badge badge-${type}`}>{displayLabel}</span>
