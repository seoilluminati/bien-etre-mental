---
export interface Props {
  href: string;
  label?: string;
  size?: 'normal' | 'large' | 'full';
  pulse?: boolean;
}
const { href, label = "Voir sur Amazon", size = "normal", pulse = false } = Astro.props;
const tag = "materielgamer-21";
const finalHref = href.includes('tag=') ? href : (href.includes('?') ? `${href}&tag=${tag}` : `${href}?tag=${tag}`);
const sizeClass = size === 'large' ? 'btn-lg' : size === 'full' ? 'btn-full' : '';
const pulseClass = pulse ? 'pulse' : '';
---
<div class="amazon-cta-wrapper">
  <a href={finalHref} class={`btn-amazon ${sizeClass} ${pulseClass}`} target="_blank" rel="nofollow noopener sponsored" title={label}>
    🛒 {label} →
  </a>
  <span class="urgency-text">🔥 Prix vérifié aujourd'hui</span>
</div>
