---
export interface Props {
  note: number;
  max?: number;
}
const { note, max = 10 } = Astro.props;
const stars = Math.round(note / 2);
const noteColor = note >= 8 ? 'var(--note-high)' : note >= 6 ? 'var(--note-mid)' : 'var(--note-low)';
---
<div class="rating-display">
  <span class="note" style={`color: ${noteColor}`}>{note}<span style="font-size:0.6em;opacity:0.5">/{max}</span></span>
  <div class="stars">
    {Array.from({length: 5}).map((_, i) => (
      <span class={i < stars ? 'star' : 'star star-empty'}>★</span>
    ))}
  </div>
  <div class="progress-bar">
    <div class="fill" style={`width: ${(note/max)*100}%; background: ${noteColor};`}></div>
  </div>
</div>

<style>
  .rating-display { display: flex; flex-direction: column; gap: 0.3rem; }
  .note { font-size: var(--text-xl); font-weight: 800; }
  .stars { font-size: 0.9rem; }
  .star { color: var(--star); }
  .star-empty { opacity: 0.2; }
</style>
